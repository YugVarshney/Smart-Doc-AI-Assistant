# App configurations
PROJECT_NAME="Smart Doc AI Assistant"

# Database Connections
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smartdoc
DATABASE_FALLBACK_SQLITE=true
SQLITE_URL=sqlite:///./smartdoc.db

# Cache Configurations
REDIS_URL=redis://localhost:6379/0

# Auth Secrets
SECRET_KEY=supersecretkeychangeinproduction1234567890

# OCR Credentials (Azure Form Recognizer)
AZURE_OCR_ENDPOINT=
AZURE_OCR_KEY=
POPPLER_PATH=
TESSERACT_CMD=

# LLM Configs (stub | openai)
LLM_BACKEND=stub
LLM_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_MODEL=gpt-4o-mini

# Embedding Configs (local | openai)
EMBEDDING_BACKEND=local

# Reranker Configurations
RERANK_ENABLED=true
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
